{
  "version": 1,
  "model": "mock:gpt-freecode-test",
  "steps": [
    {
      "match": {
        "turn": 1,
        "provider": "mock",
        "model": "gpt-freecode-test",
        "messageCount": 1,
        "mustContain": ["Create a file named hello.txt"],
        "toolsAvailable": ["write_file"],
        "systemPromptPresent": true,
        "toolRationale": true,
        "parallelTools": true,
        "nativeToolsSupplied": true
      },
      "response": {
        "chunks": ["I'll create hello.txt."],
        "toolCalls": [
          {
            "name": "write_file",
            "args": {
              "path": "hello.txt",
              "content": "Hello, World!"
            }
          }
        ],
        "usage": {
          "promptTokens": 20,
          "outputTokens": 6,
          "totalTokens": 26
        }
      }
    },
    {
      "match": {
        "turn": 2,
        "provider": "mock",
        "model": "gpt-freecode-test",
        "messageCount": 3,
        "mustContain": ["<tool_result name=\"write_file\">"],
        "toolsAvailable": ["write_file"],
        "toolRationale": true,
        "parallelTools": true,
        "nativeToolsSupplied": true
      },
      "response": {
        "text": "Created hello.txt.",
        "usage": {
          "promptTokens": 30,
          "outputTokens": 4,
          "totalTokens": 34
        }
      }
    }
  ]
}
