{
  "name": "tty-help-output",
  "description": "Submitting /help renders the command list in the scroll region while the input prompt remains pinned at the bottom; slash suggestion overlay opens and restores cleanly over the output",
  "requiresLlm": false,
  "tty": {
    "cols": 80,
    "rows": 24,
    "readyText": "for commands",
    "steps": [
      {
        "name": "type /help",
        "send": "/help",
        "screenContains": [
          "> /help"
        ]
      },
      {
        "name": "submit — help text scrolls in, prompt stays at bottom",
        "send": "\r",
        "waitFor": "Available commands",
        "screenContains": [
          "Available commands",
          "/clear",
          "/keys",
          "/model",
          "> / for commands"
        ]
      },
      {
        "name": "open slash suggestions over command output",
        "send": "/",
        "screenContains": [
          "/clear",
          "/config",
          "> /"
        ]
      },
      {
        "name": "backspace closes suggestions without leaving a blank hole",
        "send": "",
        "quietMs": 500,
        "screenContains": [
          "Flags:",
          "-log  Enable diagnostic logging to stderr",
          "> / for commands"
        ]
      },
      {
        "name": "second open — overlay reopens cleanly",
        "send": "/",
        "screenContains": [
          "/clear",
          "/config",
          "> /"
        ]
      },
      {
        "name": "second backspace — overlay restores again with correct content",
        "send": "",
        "quietMs": 500,
        "screenContains": [
          "Flags:",
          "-log  Enable diagnostic logging to stderr",
          "> / for commands"
        ]
      }
    ],
    "exit": "\u0003",
    "expectExit": true,
    "exitCode": 0
  }
}