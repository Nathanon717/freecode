{
  "name": "agent-write-file-fake",
  "description": "Fake LLM fixture drives an approved write_file tool call through the real agent loop",
  "requiresLlm": false,
  "workspace": "temp",
  "model": "mock:gpt-freecode-test",
  "llmFixture": "agent-write-file-fake.llm.json",
  "turns": [
    { "input": "Create note.txt with the text created by fake llm." },
    { "input": "y" }
  ],
  "expect": {
    "stdoutContains": ["Created note.txt."],
    "stdoutAbsent": ["FREECODE_NO_LLM=1", "No API key configured", "Real provider access is blocked"],
    "exitCode": 0,
    "files": [
      { "path": "note.txt", "contentExact": "created by fake llm\n" }
    ],
    "toolTrace": {
      "sequence": ["write_file"],
      "maxCalls": 1
    },
    "fakeLlmTrace": {
      "callCount": 2,
      "maxCalls": 2,
      "calls": [
        {
          "provider": "mock",
          "model": "gpt-freecode-test",
          "executionPath": "fake-direct",
          "inputMessageCount": 1,
          "lastUserContains": ["Create note.txt"],
          "toolsAvailable": ["write_file"],
          "toolRationale": true,
          "parallelTools": true,
          "nativeToolsSupplied": true,
          "emittedTextContains": ["I'll create the file now."],
          "emittedToolCalls": ["write_file"],
          "usage": { "promptTokens": 20, "outputTokens": 6, "totalTokens": 26 }
        },
        {
          "provider": "mock",
          "model": "gpt-freecode-test",
          "executionPath": "fake-direct",
          "inputMessageCount": 3,
          "lastUserContains": ["<tool_result name=\"write_file\">"],
          "toolsAvailable": ["write_file"],
          "toolRationale": true,
          "parallelTools": true,
          "nativeToolsSupplied": true,
          "emittedTextContains": ["Created note.txt."],
          "usage": { "promptTokens": 30, "outputTokens": 4, "totalTokens": 34 }
        }
      ]
    }
  }
}
