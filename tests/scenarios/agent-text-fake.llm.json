{
  "version": 1,
  "model": "mock:gpt-freecode-test",
  "steps": [
    {
      "match": {
        "turn": 1,
        "provider": "mock",
        "model": "gpt-freecode-test",
        "mustContain": ["Say PONG"],
        "toolsAvailable": ["read", "create", "list_dir"],
        "systemPromptPresent": true
