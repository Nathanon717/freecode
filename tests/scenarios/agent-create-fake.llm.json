{
  "version": 1,
  "model": "mock:gpt-freecode-test",
  "steps": [
    {
      "match": {
        "turn": 1,
        "provider": "mock",
        "model": "gpt-freecode-test",
        "messageCount": 1,
        "mustContain": ["Create note.txt"],
        "toolsAvailable": ["create"],
        "systemPromptPresent": true,
        "toolRationale": true,
        "parallelTools": true,
        "nativeToolsSupplied": true
      },
      "response": {
        "chunks": ["I'll create the file now."],
        "toolCalls": [
          {
            "name": "create",
            "args": {
              "path": "note.txt",
              "content": "created by fake llm\n"
            }
          }
        ],
        "usage": {
          "promptTokens": 20,
          "outputTokens": 6,
          "totalTokens": 26
        }
      }
    },
    {
      "match": {
        "turn": 2,
        "provider": "mock",
        "model": "gpt-freecode-test",
        "messageCount": 3,
        "mustContain": ["<tool_result name=\"create\">"],
        "toolsAvailable": ["create"],
        "toolRationale": true,
        "parallelTools": true,
        "nativeToolsSupplied": true
      },
      "response": {
        "text": "Created note.txt.",
        "usage": {
          "promptTokens": 30,
          "outputTokens": 4,
          "totalTokens": 34
        }
      }
    }
  ]
}
