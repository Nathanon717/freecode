{
  "name": "tty-prefix-multi-match",
  "description": "Typing /c shows /clear as the inline completion and /config as a suggestion; unrelated commands are absent",
  "requiresLlm": false,
  "tty": {
    "cols": 80,
    "rows": 24,
    "readyText": "for commands",
    "steps": [
      {
        "name": "type /c — /clear inline, /config in suggestion list",
        "send": "/c",
        "screenContains": [
          "/clear",
          "/config"
        ],
        "screenAbsent": [
          "/eval",
          "/help",
          "/keys",
          "/resume"
        ]
      },
      {
        "name": "type o — /co prefix narrows to only /config, /sources and /clear gone",
        "send": "o",
        "screenContains": [
          "> /config"
        ],
        "screenAbsent": [
          "/eval",
          "/help",
          "/keys",
          "/resume",
          "/clear"
        ]
      }
    ],
    "exit": "\u0003",
    "expectExit": true,
    "exitCode": 0
  }
}
