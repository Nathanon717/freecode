{
  "name": "06-eval-read-file-truncation",
  "description": "Easy: read_file on a file larger than 30 KB returns a truncated result with a [TRUNCATED] marker; agent reports TRUNCATED=true",
  "requiresLlm": true,
  "config": {
    "toolRationale": false,
    "useOllama": false
  },
  "workspace": "temp",
  "filesBefore": [
    {
      "path": "large.txt",
      "content": "\n"
    }
  ],
  "turns": [
    {
      "input": "Use read_file with path \"large.txt\". After the tool returns its result, reply exactly \"TRUNCATED=true\" if the result contains the text \"[TRUNCATED\", otherwise reply exactly \"TRUNCATED=false\". Do not use any other tools."
    },
    {
      "input": "y"
    }
  ],
  "expect": {
    "stdoutContains": [
      "TRUNCATED=true"
    ],
    "stdoutAbsent": [
      "Error:",
      "TRUNCATED=false"
    ],
    "exitCode": 0,
    "toolTrace": {
      "maxCalls": 1,
      "sequence": [
        "read_file"
      ],
      "absent": [
        "write_file",
        "grep",
        "list_dir",
        "shell_exec"
      ]
    }
  }
}
