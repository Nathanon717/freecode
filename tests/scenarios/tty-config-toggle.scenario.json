{
  "name": "tty-config-toggle",
  "description": "Space key toggles a boolean setting in the config editor; the changed value persists and the editor can be reopened without error",
  "requiresLlm": false,
  "config": {
    "toolRationale": false
  },
  "tty": {
    "cols": 80,
    "rows": 24,
    "readyText": "for commands",
    "steps": [
      {
        "name": "type /config",
        "send": "/config",
        "screenContains": [
          "> /config"
        ]
      },
      {
        "name": "submit — editor opens with Tool rationale selected",
        "send": "\r",
        "waitFor": "freecode config",
        "screenContains": [
          "freecode config",
          "Tool rationale"
        ]
      },
      {
        "name": "space — toggles Tool rationale from false to true",
        "send": " ",
        "screenContains": [
          "Tool rationale"
        ]
      },
      {
        "name": "q — close editor, prompt returns",
        "send": "q",
        "screenContains": [
          "> / for commands"
        ]
      },
      {
        "name": "reopen /config to verify persistence",
        "send": "/config",
        "screenContains": [
          "> /config"
        ]
      },
      {
        "name": "submit — editor reopens with Tool rationale",
        "send": "\r",
        "waitFor": "freecode config",
        "screenContains": [
          "freecode config",
          "Tool rationale"
        ]
      },
      {
        "name": "q — close editor",
        "send": "q",
        "screenContains": [
          "> / for commands"
        ]
      }
    ],
    "exit": "\u0003",
    "expectExit": true,
    "exitCode": 0
  }
}