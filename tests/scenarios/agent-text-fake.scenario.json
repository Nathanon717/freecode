{
  "name": "agent-text-fake",
  "description": "Fake LLM fixture enters the agent loop and returns deterministic text without live provider access",
  "requiresLlm": false,
  "workspace": "temp",
  "model": "mock:gpt-freecode-test",
  "llmFixture": "agent-text-fake.llm.json",
  "turns": [
    { "input": "Say PONG through the fake model." }
  ],
  "expect": {
    "stdoutContains": ["PONG"],
    "stdoutAbsent": ["FREECODE_NO_LLM=1", "No API key configured", "Real provider access is blocked"],
    "exitCode": 0,
    "fakeLlmTrace": {
      "callCount": 1,
      "maxCalls": 1,
      "calls": [
        {
          "provider": "mock",
          "model": "gpt-freecode-test",
          "lastUserContains": ["Say PONG through the fake model."],
          "toolsAvailable": ["read", "create"],
          "emittedTextContains": ["PONG"],
          "usage": { "promptTokens": 12, "outputTokens": 1, "totalTokens": 13 }
        }
      ]
    }
  }
}
