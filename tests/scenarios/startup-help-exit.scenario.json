{
  "name": "startup-help-exit",
  "description": "Boot the CLI, print help, exit cleanly",
  "requiresLlm": false,
  "turns": [
    { "input": "/help" }
  ],
  "expect": {
    "stdoutContains": ["Available commands", "Goodbye"],
    "stdoutAbsent": ["Error:", "/exit", "/quit"],
    "exitCode": 0
  }
}
