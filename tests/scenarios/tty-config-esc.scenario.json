{
  "name": "tty-config-esc",
  "description": "Submitting /config opens the standalone config editor; pressing Esc closes it, erases its screen, and restores the input prompt",
  "requiresLlm": false,
  "tty": {
    "cols": 80,
    "rows": 24,
    "readyText": "for commands",
    "steps": [
      {
        "name": "type /config",
        "send": "/config",
        "screenContains": [
          "> /config"
        ]
      },
      {
        "name": "submit — config editor opens",
        "send": "\r",
        "waitFor": "freecode config",
        "screenContains": [
          "freecode config",
          "Tool rationale"
        ]
      },
      {
        "name": "press Esc — editor closes, screen erased, prompt returns",
        "send": "\u001b",
        "waitFor": "for commands",
        "screenContains": [
          "> / for commands"
        ],
        "screenAbsent": [
          "freecode config",
          "Tool rationale"
        ]
      }
    ],
    "exit": "\u0003",
    "expectExit": true,
    "exitCode": 0
  }
}
