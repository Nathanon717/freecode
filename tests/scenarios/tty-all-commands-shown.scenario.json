{
  "name": "tty-all-commands-shown",
  "description": "Typing / shows all slash commands in the suggestion list",
  "requiresLlm": false,
  "tty": {
    "cols": 80,
    "rows": 24,
    "readyText": "for commands",
    "steps": [
      {
        "name": "type / — all commands appear as suggestions",
        "send": "/",
        "screenContains": [
          "/clear",
          "/config",
          "/eval",
          "/help",
          "/humaneval",
          "/keys",
          "/model"
        ]
      }
    ],
    "exit": "\u0003",
    "expectExit": true,
    "exitCode": 0
  }
}
