{
  "name": "tty-eval-then-config-picker",
  "description": "After a fake eval completes, another raw picker can still receive input and Ctrl-C exits cleanly",
  "requiresLlm": false,
  "model": "mock:gpt-freecode-test",
  "llmFixture": "eval-cereal-soup-fake.llm.json",
  "config": {
    "defaultModel": "mock:gpt-freecode-test",
    "toolConfirmation": "auto"
  },
  "tty": {
    "cols": 80,
    "rows": 24,
    "readyText": "for commands",
    "steps": [
      {
        "name": "type /eval",
        "send": "/eval",
        "screenContains": [
          "> /eval"
        ]
      },
      {
        "name": "submit - eval picker opens",
        "send": "\r",
        "waitFor": "cereal-soup",
        "screenContains": [
          "cereal-soup"
        ]
      },
      {
        "name": "open action menu on first eval",
        "send": "\r",
        "waitFor": "Enter select",
        "screenContains": [
          "Run"
        ]
      },
      {
        "name": "run first eval",
        "send": "\r",
        "waitFor": "tokens:",
        "waitForMs": 25000,
        "quietMs": 600,
        "screenContains": [
          "PASS  cereal-soup"
        ]
      },
      {
        "name": "type /config after eval",
        "send": "/config",
        "screenContains": [
          "> /config"
        ]
      },
      {
        "name": "submit - config picker accepts input",
        "send": "\r",
        "waitFor": "Tool rationale",
        "quietMs": 600,
        "screenContains": [
          "Tool rationale",
          "Tool rationale"
        ]
      },
      {
        "name": "close config picker",
        "send": "q",
        "waitFor": "for commands",
        "screenContains": [
          "> / for commands"
        ]
      }
    ],
    "exit": "\u0003",
    "expectExit": true,
    "exitCode": 0
  }
}
