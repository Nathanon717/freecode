{
  "name": "tty-fuzzy-completion",
  "description": "Fuzzy query /ss matches /status; Tab expands the buffer to /status, Enter submits and shows the status output",
  "requiresLlm": false,
  "tty": {
    "cols": 80,
    "rows": 24,
    "readyText": "for commands",
    "steps": [
      {
        "name": "type /ss — fuzzy matches /status but no inline suffix (completion is not a prefix)",
        "send": "/ss",
        "screenContains": [
          "> /ss"
        ],
        "screenAbsent": [
          "/clear",
          "/config",
          "/eval",
          "/help"
        ]
      },
      {
        "name": "tab expands buffer to /status",
        "send": "\t",
        "screenContains": [
          "> /status"
        ]
      },
      {
        "name": "enter submits /status — Environment section appears in scroll region",
        "send": "\r",
        "waitFor": "Environment",
        "screenContains": [
          "Environment",
          "> / for commands"
        ]
      }
    ],
    "exit": "\u0003",
    "expectExit": true,
    "exitCode": 0
  }
}