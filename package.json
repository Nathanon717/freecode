{
  "name": "freecode",
  "version": "0.1.0",
  "description": "Token-optimised CLI coding agent with free LLM provider rotation",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "freecode": "dist/index.js",
    "pty": "./pty"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "npm run build && npm run docs:generate && npm run verify:scenarios && vitest run --exclude tests/harness/pty/driver.test.ts --exclude tests/harness/pty/session.test.ts",
    "test:pty": "vitest run tests/harness/pty/driver.test.ts tests/harness/pty/session.test.ts",
    "unit:watch": "vitest",
    "coverage": "vitest run --coverage",
    "docs:generate": "tsx scripts/sync-docs.ts",
    "verify:scenarios": "tsx tests/harness/run-scenarios.ts --no-build --skip-llm",
    "pty:session": "cross-env MSYS_NO_PATHCONV=1 tsx tests/harness/pty/session.ts"
  },
  "keywords": [
    "cli",
    "coding",
    "agent",
    "llm",
    "ai"
  ],
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^0.0.56",
    "@ai-sdk/openai": "^0.0.66",
    "ai": "^3.4.0",
    "chalk": "^5.3.0",
    "codex": "^0.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.4",
    "@xterm/headless": "^6.0.0",
    "cross-env": "^10.1.0",
    "node-pty": "^1.1.0",
    "playwright": "^1.60.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4"
  }
}
