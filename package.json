{
  "name": "freecode",
  "version": "0.1.0",
  "description": "Token-optimised CLI coding agent with free LLM provider rotation",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "freecode": "dist/index.js",
    "pty": "./pty"
  },
  "scripts": {
    "postinstall": "node scripts/ensure-pty.cjs && node scripts/ensure-link.cjs",
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "tsx scripts/test.ts",
    "time": "tsx scripts/time.ts",
    "test:pty": "vitest run tests/harness/pty/driver.test.ts tests/harness/pty/session.test.ts",
    "unit:watch": "vitest",
    "coverage": "vitest run --coverage",
    "docs:generate": "tsx scripts/sync-docs.ts",
    "verify:scenarios": "tsx tests/harness/run-scenarios.ts --no-build --skip-llm",
    "pty:session": "cross-env MSYS_NO_PATHCONV=1 tsx tests/harness/pty/session.ts",
    "lint": "eslint src tests scripts --cache",
    "lint:fix": "eslint src tests scripts --cache --fix"
  },
  "keywords": [
    "cli",
    "coding",
    "agent",
    "llm",
    "ai"
  ],
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^0.0.56",
    "@ai-sdk/openai": "^0.0.66",
    "@libsql/client": "^0.17.4",
    "@vscode/ripgrep": "^1.18.0",
    "ai": "^3.4.0",
    "chalk": "^5.3.0",
    "claude": "^0.1.1",
    "doppler": "^1.0.0",
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.4",
    "@xterm/headless": "^6.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.1",
    "node-pty": "^1.1.0",
    "playwright": "^1.60.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.4"
  }
}
