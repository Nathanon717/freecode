{
  "name": "freecode",
  "version": "0.1.0",
  "description": "Token-optimised CLI coding agent with free LLM provider rotation",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "freecode": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "tsx src/index.ts --test",
    "test-all": "tsx src/index.ts --test-all",
    "unit": "vitest run",
    "unit:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test-env": "node test-env.js",
    "docs:generate": "tsx scripts/generate-docs.ts",
    "docs:check": "tsx scripts/generate-docs.ts && tsx scripts/check-map.ts",
    "verify:scenarios": "tsx tests/harness/run-scenarios.ts --no-build --skip-llm",
    "verify": "npm run build && npm run docs:check && npm run verify:scenarios",
    "verify:fast": "npm run docs:check && npm run verify:scenarios",
    "eval": "npm run build && tsx tests/harness/run-scenarios.ts --no-build --only-llm --details"
  },
  "keywords": [
    "cli",
    "coding",
    "agent",
    "llm",
    "ai"
  ],
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^0.0.56",
    "@ai-sdk/openai": "^0.0.66",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^3.4.0",
    "chalk": "^5.3.0",
    "codex": "^0.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.4",
    "@xterm/headless": "^6.0.0",
    "node-pty": "^1.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4"
  }
}
